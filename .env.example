# Decision Provenance Explorer - Environment Variables
# Copy to .env and fill in values

# ============================================================================
# Frontend (Vite)
# ============================================================================
VITE_API_BASE_URL=http://localhost:8000

# ============================================================================
# Backend (FastAPI)
# ============================================================================

# Database
DB_PATH=provenance.db

# POKT Network RPC (Polygon Amoy)
POKT_RPC_URL=https://lb.nodies.app/v2/polygon-amoy

# Contract Address (your deployed ProvenanceRegistry contract)
CONTRACT_ADDRESS=0x8E6e5B004818A796C8D4B098aCaD5cD86b9F4c32

# Address that signs/submits anchor() txns (public address derived from
# PROVENANCE_SIGNER_KEY). Anchors are stored per-sender on-chain, so reads
# must use this address, NOT the contract address. Update if you rotate keys.
ANCHOR_SIGNER_ADDRESS=0x8e50426474338c47B5D4936176AD3D3Dba9261Ae

# Polygonscan API Key (for contract verification)
POLYGONSCAN_API_KEY=

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Model Defaults
DEFAULT_MODEL_ID=loan_scorer
DEFAULT_MODEL_VERSION=2.3.1

# Logging
LOG_LEVEL=INFO
DEBUG=false

# ============================================================================
# Optional: EVM Anchoring (for decision-provenance library)
# ============================================================================
# PROVENANCE_SIGNER_KEY=your_private_key_here
# EVM_ANCHOR_EVERY=100